<?xml version="1.0" encoding="utf-8" ?>

<configuration>

	<appSettings>

		<add key="W_threshold" value="50" />

		<add key="L_threshold" value="0.70" />

		<add key="AllowedDeviation" value="0.25" />

		<add key="storagePath" value="Sessions" />

	</appSettings>

	<startup>

		<supportedRuntime
		  version="v4.0"
		  sku=".NETFramework,Version=v4.7.2" />

	</startup>

	<system.serviceModel>

		<bindings>

			<netTcpBinding>

				<binding
				  name="DroneNetTcpBinding"

				  transferMode="Buffered"

				  maxReceivedMessageSize="2147483647"

				  openTimeout="00:01:00"

				  closeTimeout="00:01:00"

				  sendTimeout="00:10:00"

				  receiveTimeout="00:10:00" />

			</netTcpBinding>

		</bindings>

		<services>

			<service name="Service.DroneService">

				<host>

					<baseAddresses>

						<add
						  baseAddress=
              "net.tcp://localhost:4000/DroneMonitoring" />

					</baseAddresses>

				</host>

				<endpoint
				  address="Service"

				  binding="netTcpBinding"

				  bindingConfiguration=
          "DroneNetTcpBinding"

				  contract="Common.IDroneService" />

			</service>

		</services>

	</system.serviceModel>

</configuration>